#include "../push_swap.h"

void	improve(t_ops **ops)
{
	t_ops **last;
	t_ops *iter;
	int *rots;

	rots = ft_calloc(sizeof(int), 3);
	rots[A] = 0;
	rots[B] = 0;
	iter = (*ops)->nxt;
	last[A] = ops;
	last[B] = ops;
	while (last[A] && last[B])
	{
		rots = count_rot(iter->op, rots);
		if (!(is_a(iter->op)) && !(is_b(iter->op)))
			check_rot(iter, last, rots);
		if (!(iter->nxt))
		{
			check_rot(iter->op, last, rots);
			break;
		}
		iter = iter->nxt;
	}
	combine_rot(ops);
}

void	check_rot(t_ops *iter, t_ops **last, int *rots)
{
	if (last[A] && (!(ft_strncmp(iter->op, "pb", 2)) || !(ft_strncmp(iter->op, "sa", 2))))
		if (rots[A] > ((last[A])->ln_a) / 2)
		{
			rots[A] = 0;
			reverse_rot(&(last[A]));
			if (iter->nxt)
				last[A] = iter->nxt;
			else
				last[A] = NULL;
		}
	if (last[B] && (!(ft_strncmp(iter->op, "pa", 2)) || !(ft_strncmp(iter->op, "sb", 2))))
		if (rots[B] > ((last[B])->ln_b) / 2)
		{
			rots[B] = 0;
			reverse_rot(&(last[B]));
			if (iter->nxt)
				last[B] = iter->nxt;
			else
				last[B] = NULL;
			
		}
}

