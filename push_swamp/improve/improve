int *count_rot(char *op, int *rots)
{
	if (is_a(op))
		rots[A] ++;
	if (is_b(op))
		rots[B] ++;
	return(rots);
}

bool is_a(op)
{
	if (!(ft_strncmp(op, "ra", 2)) || !(ft_strncmp(op, "rra", 3))|| !(ft_strncmp(op, "rrr", 3))|| !(ft_strncmp(op, "rr", 3)))
		return (1);
	return(0);
}

bool is_b(op)
{
	if (!(ft_strncmp(op, "rb", 2)) || !(ft_strncmp(op, "rrb", 3)) || !(ft_strncmp(op, "rrr", 3)) || !(ft_strncmp(op, "rr", 3)))
